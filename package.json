{
  "name": "khazad-doom",
  "version": "0.1.0",
  "description": "Local daemon for JSON Issue Slice workflows; Pi bridges starts/explanations while Herdr shows live cockpits",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Sivanirosh/khazad-doom.git"
  },
  "type": "commonjs",
  "keywords": [
    "pi-package",
    "khazad-doom",
    "agentic-workflow",
    "pi-extension",
    "herdr-cockpit",
    "daemon-feed"
  ],
  "scripts": {
    "check:extension": "node --check extensions/khazad-monitor/index.js && node --check extensions/khazad-worker/index.js",
    "test": "node --test extensions/khazad-monitor/index.test.mjs extensions/khazad-worker/index.test.mjs tests/*.test.mjs",
    "test:extension": "node --test extensions/khazad-monitor/index.test.mjs extensions/khazad-worker/index.test.mjs tests/*.test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions/khazad-monitor"
    ]
  }
}
