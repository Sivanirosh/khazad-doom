{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://khazad-doom.local/mission-envelope.schema.json",
  "title": "Khazad-Doom Mission Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "goal",
    "allowed_areas"
  ],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "allowed_areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!\\s)(?!/)(?!\\.\\/)(?!.*\\.\\.)(?!.*[\\*\\?\\[\\]])(?!.*\\s$).+$",
        "description": "Repo-relative literal path prefix using the same area contract as slice areas."
      },
      "uniqueItems": true
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verify_profile": {
      "type": "string",
      "minLength": 1,
      "default": "default"
    },
    "max_auto_promotions": {
      "type": "integer",
      "minimum": 0
    },
    "max_depth": {
      "type": "integer",
      "minimum": 0
    },
    "max_generated_slices": {
      "type": "integer",
      "minimum": 0
    },
    "autonomy_level": {
      "type": "string",
      "enum": [
        "off",
        "shadow",
        "promote",
        "run"
      ],
      "default": "off"
    },
    "must_ask_if": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
