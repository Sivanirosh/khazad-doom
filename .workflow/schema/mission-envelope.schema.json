{
  "$id": "https://khazad-doom.local/mission-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "allowed_areas": {
      "items": {
        "description": "Repo-relative literal path prefix using the same area contract as slice areas.",
        "minLength": 1,
        "pattern": "^(?!\\s)(?!/)(?!\\.\\/)(?!.*\\.\\.)(?!.*[\\*\\?\\[\\]])(?!.*\\s$).+$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "autonomy_level": {
      "default": "off",
      "enum": [
        "off",
        "shadow",
        "promote",
        "run"
      ],
      "type": "string"
    },
    "goal": {
      "minLength": 1,
      "type": "string"
    },
    "max_auto_promotions": {
      "minimum": 0,
      "type": "integer"
    },
    "max_depth": {
      "minimum": 0,
      "type": "integer"
    },
    "max_generated_slices": {
      "minimum": 0,
      "type": "integer"
    },
    "must_ask_if": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "non_goals": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "verify_profile": {
      "default": "default",
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "goal",
    "allowed_areas"
  ],
  "title": "Khazad-Doom Mission Envelope",
  "type": "object"
}
